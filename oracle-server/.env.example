# ─── Oracle 錢包（呼叫 submitResult 的私鑰，不含 0x）
ORACLE_PRIVATE_KEY=your_private_key_here

# ─── Oracle 錢包地址（與私鑰對應）
ORACLE_ADDRESS=0x...

# ─── Tempo Moderato 合約地址
CONTRACT_ADDRESS=0xcAC5B9d2817325E78090E3Ce4b9C299C819cF953

# ─── pathUSD 預編譯地址（固定不變）
PATHUSD_ADDRESS=0x20c0000000000000000000000000000000000000

# ─── Tempo RPC
RPC_URL=https://rpc.moderato.tempo.xyz

# ─── OpenWeather API Key
# 免費版支援 current + 5 天 forecast，申請：https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# ─── MPP nonce 簽名密鑰（隨機產生，不要外洩）
# 產生方法：openssl rand -hex 32
ORACLE_SECRET=your_random_secret_here

# ─── Server port
ORACLE_PORT=3001
