# ─────────────────────────────────────────────
# Tempo Weather Market — Oracle Server
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Network selection: "testnet" or "mainnet"
TEMPO_NETWORK=testnet

# OpenWeather API key (free tier works)
# Get yours at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# WeatherAPI key (https://www.weatherapi.com/ - free tier 1M calls/month)
WEATHERAPI_KEY=your_weatherapi_key_here

# ── Testnet (Moderato) ────────────────────────
# Chain ID: 42431
# RPC: https://rpc.moderato.tempo.xyz
# pathUSD: 0x20c0000000000000000000000000000000000000
CONTRACT_ADDRESS_TESTNET=0xcAC5B9d2817325E78090E3Ce4b9C299C819cF953
RPC_TESTNET=https://rpc.moderato.tempo.xyz
PATHUSD_ADDRESS=0x20c0000000000000000000000000000000000000

# ── Mainnet ───────────────────────────────────
# Chain ID: 4217
# RPC: https://rpc.tempo.xyz
# USDCE: 0x20C000000000000000000000b9537d11c60E8b50
CONTRACT_ADDRESS_MAINNET=0x072a3a0c04cf8cdcaf5b4a73a4ed4ff5a841531f
RPC_MAINNET=https://rpc.tempo.xyz
USDCE_ADDRESS=0x20C000000000000000000000b9537d11c60E8b50

# Oracle wallet private key (needs stablecoin balance for gas)
# ⚠️  Never commit your real private key
ORACLE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Oracle server port
ORACLE_PORT=3001
