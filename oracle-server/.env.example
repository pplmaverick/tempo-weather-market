# ─────────────────────────────────────────────
# Tempo Weather Market — Oracle Server
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Network selection: "testnet" or "mainnet" (default: testnet)
TEMPO_NETWORK=testnet

# OpenWeather API key, required on both networks (free tier works)
# Get yours at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# WeatherAPI key, used for the 3-source median (https://www.weatherapi.com/ - free tier 1M calls/month)
WEATHERAPI_KEY=your_weatherapi_key_here

# HMAC secret used to sign/verify MPP payment nonces, required on both networks
ORACLE_SECRET=your_oracle_secret_here

# Oracle wallet address, used as the MPP payment recipient, required on both networks
ORACLE_ADDRESS=0xYOUR_ORACLE_WALLET_ADDRESS

# ── Testnet (Moderato) ────────────────────────
# Chain ID: 42431
# WeatherMarket contract address on Moderato testnet, required when TEMPO_NETWORK=testnet
CONTRACT_ADDRESS=0xcAC5B9d2817325E78090E3Ce4b9C299C819cF953
# Moderato RPC URL, optional (default: https://rpc.moderato.tempo.xyz)
RPC_URL=https://rpc.moderato.tempo.xyz
# pathUSD precompile address on Moderato testnet, required when TEMPO_NETWORK=testnet
PATHUSD_ADDRESS=0x20c0000000000000000000000000000000000000

# ── Mainnet ───────────────────────────────────
# Chain ID: 4217
# WeatherMarket contract address on Tempo mainnet, required when TEMPO_NETWORK=mainnet
CONTRACT_ADDRESS_MAINNET=0x072a3a0c04cf8cdcaf5b4a73a4ed4ff5a841531f
# Tempo mainnet RPC URL, optional (default: https://rpc.tempo.xyz)
RPC_MAINNET=https://rpc.tempo.xyz
# USDC.e address on Tempo mainnet, required when TEMPO_NETWORK=mainnet
USDCE_ADDRESS=0x20C000000000000000000000b9537d11c60E8b50

# Oracle wallet private key (needs stablecoin balance for gas), required on both networks
# ⚠️  Never commit your real private key
ORACLE_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Oracle server port, optional (default: 3001)
ORACLE_PORT=3001
