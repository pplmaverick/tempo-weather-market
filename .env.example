# 部署者錢包私鑰（不含 0x 前綴）
PRIVATE_KEY=your_private_key_here

# Tempo 網路 RPC（可選，已有預設值）
MODERATO_RPC_URL=https://rpc.moderato.tempo.xyz
TEMPO_RPC_URL=https://rpc.tempo.xyz

# Oracle 服務錢包地址（呼叫 submitResult 的地址）
ORACLE_ADDRESS=0x...

# Tempo Scheduler 預編譯地址（不確定時留空，等官方文件確認）
# 留空 = 停用自動排程，改為手動呼叫 lockMarket()
SCHEDULER_ADDRESS=

# MPP: oracle 每次呼叫 submitResult 需支付的費用（單位：stablecoin）
# 例如 "1.0" = 1 pathUSD；留空或 "0" = 免費
ORACLE_FEE_AMOUNT=0

# testnet stablecoin 地址（Tempo Moderato pathUSD 預編譯，固定不變）
PATHUSD_ADDRESS=0x20c0000000000000000000000000000000000000

# testnet 合約地址（部署後由腳本提示填入）
WEATHER_MARKET_ADDRESS=0x...

# mainnet stablecoin 地址
USDCE_ADDRESS=0x...

# mainnet 合約地址（部署後由腳本提示填入）
WEATHER_MARKET_MAINNET_ADDRESS=0x...

# MPP Oracle HTTP Server
ORACLE_PORT=3000
ORACLE_SECRET=your_oracle_secret_here
